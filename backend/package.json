{
  "name": "clawconsole-backend",
  "version": "0.1.0",
  "description": "ClawConsole — OpenClaw Enterprise Management Platform Backend",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/ tests/",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/websocket": "^11.0.0",
    "@langchain/anthropic": "^1.3.22",
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.0",
    "@types/ws": "^8.18.1",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "js-yaml": "^4.1.0",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0",
    "p-map": "^7.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.1.0",
    "ws": "^8.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.4",
    "@types/ssh2": "^1.15.4",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
